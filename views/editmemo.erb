<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>メモ編集</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <h3>メモアプリ</h3>

        <form action="/memos/<%= @memo[:id] %>" method="post">
            <input type="hidden" name="_method" value="patch">
            <input name="title" class="input-box" type="text" placeholder="タイトル" value="<%= @memo[:title] %>">

            <textarea name="content" class="textarea-box" placeholder="内容"><%= @memo[:content] %></textarea>

            <button class="button" type="submit">変更</button>
        </form>
    </div>
</body>
